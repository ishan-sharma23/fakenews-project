# MongoDB Connection String
# For local machine -> Docker Mongo (host port mapping): mongodb://localhost:27018/capstoneproject
# For Docker backend runtime: mongodb://mongodb:27017/capstoneproject
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/capstoneproject
MONGO_URI=mongodb://localhost:27018/capstoneproject

# JWT Secret Key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Google OAuth Client ID (get from Google Cloud Console)
# Visit: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Server Port
PORT=5000

# ML Service URL
ML_SERVICE_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
