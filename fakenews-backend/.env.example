# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/fakenews
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/fakenews
MONGO_URI=mongodb://localhost:27017/fakenews

# JWT Secret Key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Google OAuth Client ID (get from Google Cloud Console)
# Visit: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Server Port
PORT=5000

# ML Service URL
ML_SERVICE_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
